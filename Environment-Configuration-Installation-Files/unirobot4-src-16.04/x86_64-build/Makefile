	$(MAKE) -f CMakeFiles/Makefile2 team_monitor_autogen
.PHONY : team_monitor_autogen

# fast build rule for target.
team_monitor_autogen/fast:
	$(MAKE) -f src/tools/debuger/team_monitor/CMakeFiles/team_monitor_autogen.dir/build.make src/tools/debuger/team_monitor/CMakeFiles/team_monitor_autogen.dir/build
.PHONY : team_monitor_autogen/fast

